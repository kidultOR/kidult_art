# ══════════════════════════════════════════
# .gitignore — kidult-art (Vite + TypeScript + three.js)
# ══════════════════════════════════════════

# ── Dependencies ──
node_modules/
.pnp
.pnp.js

# ── Build output ──
dist/
build/
*.local

# ── Vite ──
.vite/

# ── Environment variables ──
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── IDE / Editors ──
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/

# ── OS files ──
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── TypeScript ──
*.tsbuildinfo

# ── Testing ──
coverage/
*.lcov
.nyc_output

# ── Cache ──
.eslintcache
.cache/
.parcel-cache/

# ── Misc ──
*.pem
*.p12
*.key

# ── 3D assets (large files — keep in Git LFS or exclude) ──
# Uncomment if using Git LFS for large binary assets:
# *.glb
# *.gltf
# *.fbx
# *.blend
# *.blend1
# *.max
# *.ma
# *.mb

# ── Blender backup files ──
*.blend1
*.blend2

# ── Lighthouse / performance reports ──
.lighthouseci/
lighthouse-report.*

# ── Vercel / Netlify (if used as backup) ──
.vercel
.netlify

# ── Sentry ──
.sentryclirc
